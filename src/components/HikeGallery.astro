---
import { ChevronLeft, ChevronRight, X } from "@lucide/astro";

const {
  title = "Galleria",
  subtitle = "Foto della giornata",
  images = []
} = Astro.props;

const galleryId = `gallery-${Math.random().toString(36).slice(2, 10)}`;
---

<section class="space-y-4" id={galleryId} data-gallery-root>
  <div>
    <p class="text-sm font-bold uppercase tracking-[0.16em] text-terracotta-600">{title}</p>
    <h2 class="mt-2 text-3xl font-black text-forest-800">{subtitle}</h2>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    {images.map((image, index) => (
      <figure class="overflow-hidden rounded-[1.75rem] bg-white shadow-card">
        <button
          type="button"
          class="group block w-full text-left"
          data-lightbox-trigger
          data-lightbox-index={index}
          data-lightbox-src={image.src}
          data-lightbox-alt={image.alt}
          data-lightbox-caption={image.caption || ""}
          aria-label={`Apri immagine ${index + 1} in grande`}
        >
          <img
            src={image.src}
            alt={image.alt}
            loading="lazy"
            class="aspect-[4/3] w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          />
        </button>
        {image.caption && <figcaption class="px-5 py-4 text-sm text-forest-700">{image.caption}</figcaption>}
      </figure>
    ))}
  </div>

  <dialog data-lightbox-dialog class="gallery-lightbox m-0 h-full w-full max-h-none max-w-none border-0 bg-transparent p-0 text-left text-white">
    <div class="gallery-lightbox__shell relative flex min-h-screen w-full items-center justify-center px-1 py-4 sm:px-6 sm:py-6">
      <button
        type="button"
        class="gallery-lightbox__backdrop absolute inset-0 border-0 bg-transparent"
        data-lightbox-close
        aria-label="Chiudi lightbox"
      ></button>

      <div class="relative z-10 flex w-full max-w-[min(100vw,1600px)] items-center justify-center">
        <figure class="relative flex w-full flex-col items-center justify-center px-0 pb-20 sm:px-16 sm:pb-16 lg:px-20">
          <button
            type="button"
            class="absolute -bottom-16 left-1/2 z-30 inline-flex h-12 w-12 -translate-x-1/2 items-center justify-center rounded-full border border-white/25 bg-white/10 text-white backdrop-blur-sm transition hover:bg-white/16 sm:-bottom-14"
            data-lightbox-close
            aria-label="Chiudi lightbox"
          >
            <X class="h-5 w-5" stroke-width={2.4} aria-hidden="true" />
          </button>

          <button
            type="button"
            class="absolute left-0 top-1/2 inline-flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-white/25 bg-white/10 text-white backdrop-blur-sm transition hover:bg-white/16 sm:left-2 sm:h-14 sm:w-14"
            data-lightbox-prev
            aria-label="Immagine precedente"
          >
            <ChevronLeft class="h-6 w-6" stroke-width={2.4} aria-hidden="true" />
          </button>

          <img
            src=""
            alt=""
            data-lightbox-image
            class="max-h-[82vh] w-full max-w-full object-contain sm:max-h-[86vh] sm:w-auto"
          />

          <button
            type="button"
            class="absolute right-0 top-1/2 inline-flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border border-white/25 bg-white/10 text-white backdrop-blur-sm transition hover:bg-white/16 sm:right-2 sm:h-14 sm:w-14"
            data-lightbox-next
            aria-label="Immagine successiva"
          >
            <ChevronRight class="h-6 w-6" stroke-width={2.4} aria-hidden="true" />
          </button>

          <figcaption class="mt-4 flex w-full max-w-xl flex-col gap-1 rounded-[1.5rem] bg-cream/92 px-4 py-3 text-center text-forest-800 shadow-lg backdrop-blur-sm">
            <p class="text-sm font-medium text-forest-800" data-lightbox-caption></p>
          </figcaption>
        </figure>
      </div>
    </div>
  </dialog>
</section>

<style>
  .gallery-lightbox::backdrop {
    background: rgba(9, 16, 13, 0.94);
  }

  .gallery-lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-gallery-root]:not([data-gallery-ready])').forEach((root) => {
    root.dataset.galleryReady = 'true';

    const dialog = root.querySelector('[data-lightbox-dialog]');
    const triggers = Array.from(root.querySelectorAll('[data-lightbox-trigger]'));
    const image = dialog?.querySelector('[data-lightbox-image]');
    const caption = dialog?.querySelector('[data-lightbox-caption]');
    const prevButton = dialog?.querySelector('[data-lightbox-prev]');
    const nextButton = dialog?.querySelector('[data-lightbox-next]');
    const closeButtons = dialog ? Array.from(dialog.querySelectorAll('[data-lightbox-close]')) : [];

    if (!dialog || !image || !caption || !triggers.length) return;

    const items = triggers.map((trigger) => ({
      src: trigger.dataset.lightboxSrc || '',
      alt: trigger.dataset.lightboxAlt || '',
      caption: trigger.dataset.lightboxCaption || ''
    }));

    let currentIndex = 0;

    const render = () => {
      const item = items[currentIndex];
      image.src = item.src;
      image.alt = item.alt;
      caption.textContent = item.caption;
    };

    const open = (index) => {
      currentIndex = index;
      render();
      if (!dialog.open) dialog.showModal();
    };

    const close = () => {
      if (dialog.open) dialog.close();
    };

    const goTo = (delta) => {
      currentIndex = (currentIndex + delta + items.length) % items.length;
      render();
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => open(index));
    });

    prevButton?.addEventListener('click', () => goTo(-1));
    nextButton?.addEventListener('click', () => goTo(1));
    closeButtons.forEach((button) => button.addEventListener('click', close));

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) close();
    });

    dialog.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        goTo(-1);
      }
      if (event.key === 'ArrowRight') {
        event.preventDefault();
        goTo(1);
      }
    });
  });
</script>
