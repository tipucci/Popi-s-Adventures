---
import "../styles/global.css";
import { withBase } from "../utils/base.js";
import { getEscursioni } from "../data/escursioni.js";

const {
  title = "Popi's Adventures",
  description = "Diario di escursioni tra natura, panorami e camminate con il cane.",
  active = "home",
  image = "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80"
} = Astro.props;

const navItems = [
  {
    id: "home",
    href: withBase("/"),
    label: "Home",
    icon: "home"
  },
  {
    id: "escursioni",
    href: withBase("/escursioni"),
    label: "Escursioni",
    icon: "trail"
  },
  {
    id: "mappa",
    href: `${withBase("/escursioni")}#mappa`,
    label: "Mappa",
    icon: "map"
  }
];

function getSeasonFromDate(value) {
  if (!value) return "";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return "";

  const month = date.getMonth() + 1;
  if (month === 12 || month <= 2) return "inverno";
  if (month >= 3 && month <= 5) return "primavera";
  if (month >= 6 && month <= 8) return "estate";
  return "autunno";
}

const seasonMeta = [
  { slug: "primavera", label: "Primavera" },
  { slug: "estate", label: "Estate" },
  { slug: "autunno", label: "Autunno" },
  { slug: "inverno", label: "Inverno" }
];

const escursioni = await getEscursioni();
const provinceCounts = escursioni.reduce((groups, item) => {
  const provincia = item.provincia?.trim();
  if (!provincia) return groups;
  groups[provincia] = (groups[provincia] || 0) + 1;
  return groups;
}, {});

const seasonCounts = escursioni.reduce((groups, item) => {
  const season = getSeasonFromDate(item.data);
  if (!season) return groups;
  groups[season] = (groups[season] || 0) + 1;
  return groups;
}, {});

const allProvinceLinks = Object.entries(provinceCounts)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "it"))
  .map(([name, count]) => ({
    name,
    count,
    href: `${withBase("/escursioni")}?tag=${encodeURIComponent(name.toLowerCase())}`
  }));

const provinceLinks = allProvinceLinks.slice(0, 6);
const seasonLinks = seasonMeta.map((item) => ({
  ...item,
  count: seasonCounts[item.slug] || 0,
  href: `${withBase("/escursioni")}?stagione=${item.slug}`
}));

const footerQuickLinks = [
  { label: "Tutte le escursioni", href: withBase("/escursioni") },
  { label: "Mappa escursioni", href: `${withBase("/escursioni")}#mappa` },
  { label: "Escursioni con rifugio", href: `${withBase("/escursioni")}?soloRifugio=1` },
  { label: "Escursioni con Gea", href: `${withBase("/escursioni")}?partecipanti=gea` }
];

const iconPaths = {
  home: [
    "M3.75 10.5 12 3.75l8.25 6.75",
    "M5.25 9.75v9h4.5v-6h4.5v6h4.5v-9"
  ],
  trail: [
    "M8.25 4.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Z",
    "M10.5 20.25 9 14.25l-2.25-2.25-2.25 3",
    "M12.75 9.75 10.5 12l3 2.25 1.5 6",
    "M13.5 9h4.5l2.25-2.25"
  ],
  map: [
    "M9 18 15 21l6-3V6l-6 3-6-3-6 3v12l6-3Z",
    "M9 6v12",
    "M15 9v12"
  ]
};

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical.href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#F5EBDC" />
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-cream text-forest-800 antialiased">
    <div class="min-h-screen bg-hero-glow">
      <div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-4 pb-24 pt-4 sm:px-6 lg:px-8">
        <header class="mb-6 hidden items-center justify-between rounded-full border border-white/70 bg-white/85 px-4 py-3 shadow-card backdrop-blur md:flex">
          <a
            href={withBase("/")}
            aria-label="Torna alla home"
            class="inline-flex items-center justify-center rounded-full p-1 transition hover:bg-terracotta-50"
          >
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-forest-800 shadow-sm">
              <svg viewBox="0 0 48 48" class="h-8 w-8" aria-hidden="true">
                <circle cx="24" cy="24" r="23" fill="#355347"></circle>
                <path d="M24 10 34 24 24 38 14 24Z" fill="#F26A3D" opacity="0.92"></path>
                <circle cx="24" cy="24" r="6.5" fill="#F5EBDC"></circle>
              </svg>
            </span>
          </a>

          <nav aria-label="Navigazione principale">
            <ul class="flex items-center gap-2">
              {navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      "inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-bold transition",
                      active === item.id
                        ? "bg-terracotta-500 text-white"
                        : "text-forest-700 hover:bg-terracotta-50"
                    ]}
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0" aria-hidden="true">
                      {iconPaths[item.icon].map((path) => <path d={path}></path>)}
                    </svg>
                    <span>{item.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </header>

        <main class="flex-1">
          <slot />
        </main>

        <footer class="mt-16 overflow-hidden rounded-[2rem] border border-forest-950 bg-[#173328] text-sm text-slate-50 shadow-card">
          <div class="px-6 py-8 sm:px-8 lg:px-10 lg:py-10">
            <section class="border-b border-white/10 pb-6">
              <div class="max-w-2xl">
                <p class="font-display text-3xl text-white sm:text-[2.2rem]">Popi's Adventures</p>
                <p class="mt-3 max-w-xl text-sm leading-6 text-slate-100/86 sm:text-base">
                  Diario di cammini, salite e weekend all'aperto. Un archivio da sfogliare per trovare in fretta la prossima uscita giusta.
                </p>
              </div>
            </section>

            <div class="grid gap-8 pt-6 md:grid-cols-2 xl:grid-cols-3">
              <section aria-labelledby="footer-shortcuts" class="space-y-4">
                <div>
                  <p id="footer-shortcuts" class="text-xs font-bold uppercase tracking-[0.22em] text-emerald-100/90">
                    Scorciatoie
                  </p>
                  <p class="mt-2 text-sm text-slate-100/76">
                    I percorsi di accesso piu usati, senza rumore.
                  </p>
                </div>

                <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-1">
                  {footerQuickLinks.map((item) => (
                    <a
                      href={item.href}
                      class="rounded-[1.1rem] border border-white/14 bg-white/8 px-4 py-3 font-semibold text-slate-50 transition hover:border-white/28 hover:bg-white/14"
                    >
                      {item.label}
                    </a>
                  ))}
                </div>
              </section>

              <section aria-labelledby="footer-seasoni" class="space-y-4">
                <div>
                  <p id="footer-seasoni" class="text-xs font-bold uppercase tracking-[0.22em] text-emerald-100/90">
                    Per stagione
                  </p>
                  <p class="mt-2 text-sm text-slate-100/76">
                    Guarda le uscite del periodo che hai in mente.
                  </p>
                </div>

                <div class="grid grid-cols-2 gap-3">
                  {seasonLinks.map((item) => (
                    <a
                      href={item.href}
                      class="rounded-[1.1rem] border border-white/14 bg-white/8 px-4 py-3 transition hover:border-white/28 hover:bg-white/14"
                    >
                      <span class="block font-semibold text-white">{item.label}</span>
                      <span class="mt-1 block text-xs font-medium text-slate-100/72">{item.count} escursioni</span>
                    </a>
                  ))}
                </div>
              </section>

              <section aria-labelledby="footer-province" class="space-y-4 md:col-span-2 xl:col-span-1">
                <div class="flex items-end justify-between gap-4">
                  <div>
                    <p id="footer-province" class="text-xs font-bold uppercase tracking-[0.22em] text-emerald-100/90">
                      Per provincia
                    </p>
                    <p class="mt-2 text-sm text-slate-100/76">
                      Scegli una zona e apri subito le uscite correlate.
                    </p>
                  </div>
                  {allProvinceLinks.length > provinceLinks.length && (
                    <a
                      href={withBase("/escursioni")}
                      class="hidden text-xs font-bold uppercase tracking-[0.18em] text-slate-100/80 transition hover:text-white sm:inline"
                    >
                      Vedi tutte
                    </a>
                  )}
                </div>

                {provinceLinks.length ? (
                  <div class="flex flex-wrap gap-2">
                    {provinceLinks.map((item) => (
                      <a
                        href={item.href}
                        class="inline-flex items-center gap-2 rounded-full border border-white/16 bg-white/10 px-3 py-2 text-sm transition hover:border-white/28 hover:bg-white/16"
                      >
                        <span class="font-semibold text-white">{item.name}</span>
                        <span class="rounded-full bg-white/14 px-2 py-0.5 text-[11px] font-bold text-slate-50/84">
                          {item.count}
                        </span>
                      </a>
                    ))}
                    {allProvinceLinks.length > provinceLinks.length && (
                      <a
                        href={withBase("/escursioni")}
                        class="inline-flex items-center rounded-full border border-white/16 px-3 py-2 text-sm font-semibold text-slate-100/82 transition hover:border-white/28 hover:bg-white/10 sm:hidden"
                      >
                        Vedi tutte
                      </a>
                    )}
                  </div>
                ) : (
                  <p class="text-sm text-slate-100/76">
                    Le province compariranno qui appena il diario riceve nuove escursioni dal foglio condiviso.
                  </p>
                )}
              </section>
            </div>
          </div>
        </footer>
      </div>

      <nav class="fixed inset-x-0 bottom-4 z-50 mx-auto w-[calc(100%-1.5rem)] max-w-md rounded-full border border-white/70 bg-white/90 p-2 shadow-card backdrop-blur md:hidden">
        <ul class="grid grid-cols-3 gap-2">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "flex flex-col items-center gap-1 rounded-full px-3 py-2 text-xs font-bold transition",
                  active === item.id
                    ? "bg-terracotta-500 text-white"
                    : "text-forest-700 hover:bg-terracotta-50"
                ]}
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 shrink-0" aria-hidden="true">
                  {iconPaths[item.icon].map((path) => <path d={path}></path>)}
                </svg>
                <span>{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </body>
</html>
