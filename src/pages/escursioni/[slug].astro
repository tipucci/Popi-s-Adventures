---
import Layout from "../../layouts/Layout.astro";
import Mappa from "../../components/Mappa.jsx";
import { getEscursioni } from "../../data/escursioni.js";
import { withBase } from "../../utils/base.js";
import { formatKilometers, formatMeters } from "../../utils/format.js";

export async function getStaticPaths() {
  const escursioni = await getEscursioni();
  return escursioni.map((escursione) => ({
    params: { slug: escursione.slug },
    props: { escursione }
  }));
}

const { escursione } = Astro.props;

const partecipantiLabels = {
  meg: "Meg",
  tizi: "Tizi",
  gea: "Gea"
};

function formatDate(value) {
  if (!value) return "Data da definire";

  const parsed = new Date(`${value}T00:00:00`);
  if (Number.isNaN(parsed.getTime())) return value;

  return new Intl.DateTimeFormat("it-IT", {
    day: "2-digit",
    month: "short",
    year: "numeric"
  }).format(parsed);
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SportsActivityLocation",
  name: escursione.titolo,
  description: escursione.descrizione,
  image: escursione.foto,
  url: new URL(withBase(`/escursioni/${escursione.slug}`), Astro.site).href
};
---

<Layout
  title={`${escursione.titolo} | Popi's Adventures`}
  description={escursione.descrizione}
  image={escursione.cover}
  active="escursioni"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="space-y-8">
    <section class="overflow-hidden rounded-[2rem] bg-white shadow-card">
      <div class="relative aspect-[16/9]">
        <img
          src={escursione.cover}
          alt={escursione.titolo}
          class="h-full w-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-forest-800 via-forest-800/30 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-6 text-white sm:p-8">
          <a
            href={withBase("/escursioni")}
            class="mb-4 inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.16em] text-cream"
          >
            Torna all'archivio
          </a>
          <p class="text-sm font-bold uppercase tracking-[0.16em] text-cream/80">{escursione.luogo}</p>
          <h1 class="mt-2 font-display text-4xl sm:text-5xl">{escursione.titolo}</h1>
          <p class="mt-3 max-w-3xl text-sm text-cream/90 sm:text-base">{escursione.descrizione}</p>
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="grid gap-4 sm:grid-cols-2">
        <article class="rounded-[1.75rem] bg-white p-5 shadow-card">
          <p class="text-xs uppercase tracking-[0.16em] text-terracotta-600">Data</p>
          <p class="mt-2 text-2xl font-black text-forest-800">{formatDate(escursione.data)}</p>
        </article>
        <article class="rounded-[1.75rem] bg-white p-5 shadow-card">
          <p class="text-xs uppercase tracking-[0.16em] text-terracotta-600">Distanza</p>
          <p class="mt-2 text-2xl font-black text-forest-800">{formatKilometers(escursione.km)} km</p>
        </article>
        <article class="rounded-[1.75rem] bg-white p-5 shadow-card">
          <p class="text-xs uppercase tracking-[0.16em] text-terracotta-600">Durata</p>
          <p class="mt-2 text-2xl font-black text-forest-800">{escursione.durata}</p>
        </article>
        <article class="rounded-[1.75rem] bg-white p-5 shadow-card">
          <p class="text-xs uppercase tracking-[0.16em] text-terracotta-600">Dislivello</p>
          <p class="mt-2 text-2xl font-black text-forest-800">{formatMeters(escursione.dislivello)} m</p>
        </article>
      </div>

      <div class="space-y-4 rounded-[2rem] bg-white p-6 shadow-card">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.16em] text-terracotta-600">Compagnia</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {escursione.partecipanti.map((item) => (
              <span class="rounded-full bg-cream px-4 py-2 text-sm font-bold text-forest-700">
                {partecipantiLabels[item] || item}
              </span>
            ))}
          </div>
        </div>

        <div>
          <p class="text-sm font-bold uppercase tracking-[0.16em] text-terracotta-600">Tag</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {escursione.tag.map((item) => (
              <span class="rounded-full border border-terracotta-200 px-4 py-2 text-sm font-semibold text-terracotta-700">
                #{item}
              </span>
            ))}
          </div>
        </div>

        <div class="rounded-[1.5rem] bg-forest-50 p-5">
          <p class="text-sm font-bold uppercase tracking-[0.16em] text-forest-600">Difficolta</p>
          <p class="mt-2 text-2xl font-black text-forest-800">{escursione.difficolta}</p>
        </div>
      </div>
    </section>

    <section class="space-y-4 rounded-[2rem] bg-forest-800 p-6 text-white shadow-card">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.16em] text-cream/80">Percorso</p>
        <h2 class="mt-2 text-3xl font-black">Mappa interattiva</h2>
      </div>

      {escursione.nome_rifugio && (
        <div class="rounded-[1.5rem] border border-white/15 bg-white/10 p-5 backdrop-blur">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-cream/80">Rifugio</p>
          <p class="mt-2 text-xl font-black text-white">{escursione.nome_rifugio}</p>
        </div>
      )}

      <Mappa client:visible escursioni={[escursione]} height="420px" />
    </section>

    <section class="space-y-4">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.16em] text-terracotta-600">Galleria</p>
        <h2 class="mt-2 text-3xl font-black text-forest-800">Foto della giornata</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {escursione.foto.map((foto, index) => (
          <figure class="overflow-hidden rounded-[1.75rem] bg-white shadow-card">
            <img
              src={foto}
              alt={`${escursione.titolo} foto ${index + 1}`}
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
            />
          </figure>
        ))}
      </div>
    </section>
  </article>
</Layout>
