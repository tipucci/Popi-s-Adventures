---
import Layout from "../../layouts/Layout.astro";
import HikeGallery from "../../components/HikeGallery.astro";
import Mappa from "../../components/Mappa.jsx";
import { Star, StarHalf } from "@lucide/astro";
import { getEscursioni } from "../../data/escursioni.js";
import { withBase } from "../../utils/base.js";
import { formatKilometers, formatMeters } from "../../utils/format.js";

export async function getStaticPaths() {
  const escursioni = await getEscursioni();
  return escursioni.map((escursione) => ({ params: { slug: escursione.slug }, props: { escursione } }));
}

const { escursione } = Astro.props;
const partecipantiLabels = { meg: "Meg", tizi: "Tizi", gea: "Gea" };

function formatDate(value) {
  if (!value) return "Data da definire";
  const parsed = new Date(`${value}T00:00:00`);
  if (Number.isNaN(parsed.getTime())) return value;
  return new Intl.DateTimeFormat("it-IT", { day: "2-digit", month: "short", year: "numeric" }).format(parsed);
}

function formatMetricValue(value, formatter, suffix = "") {
  const numeric = Number(value);
  if (!Number.isFinite(numeric) || numeric <= 0) return "Non disponibile";
  return `${formatter(numeric)}${suffix}`;
}

function formatDurationValue(value) {
  const normalized = String(value || "").trim();
  if (!normalized || normalized === "0" || normalized === "0:00" || normalized === "00:00") {
    return "Non disponibile";
  }
  return normalized;
}

function getGeaRatingValue(item) {
  const rawCandidates = [item.gea_rating, item.geaRating, item.rating_gea, item.voto];
  const rawValue = rawCandidates.find((candidate) => candidate !== undefined && candidate !== null && candidate !== "");
  const numeric = Number(rawValue);
  if (!Number.isFinite(numeric)) return 0;
  return Math.max(0, Math.min(5, Math.round(numeric * 2) / 2));
}

const geaRating = getGeaRatingValue(escursione);
const geaStars = Array.from({ length: 5 }, (_, index) => {
  const slot = index + 1;
  if (geaRating >= slot) return "full";
  if (geaRating >= slot - 0.5) return "half";
  return "empty";
});
const heroDescription = String(escursione.note || "").trim();
const hasRealCover = typeof escursione.cover === "string" && !escursione.cover.startsWith("data:image/svg+xml");
const hasRealGallery = Array.isArray(escursione.gallery)
  && escursione.gallery.some((image) => typeof image?.src === "string" && !image.src.startsWith("data:image/svg+xml"));
const galleryImages = hasRealGallery ? escursione.gallery : [];
const detailGalleryImages = hasRealCover
  ? [{ src: escursione.cover, alt: escursione.coverAlt || escursione.titolo, caption: "" }, ...galleryImages]
  : galleryImages;
const jsonLdImages = [escursione.cover, ...galleryImages.map((image) => image.src)]
  .filter((src) => typeof src === "string" && !src.startsWith("data:image/svg+xml"))
  .map((src) => new URL(src, Astro.site).href);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SportsActivityLocation",
  name: escursione.titolo,
  description: escursione.descrizione,
  image: jsonLdImages,
  url: new URL(withBase(`/escursioni/${escursione.slug}`), Astro.site).href
};
---

<Layout title={`${escursione.titolo} | Popi's Adventures`} description={escursione.descrizione} image={escursione.cover} active="escursioni" mobileBackHref={withBase("/escursioni")} mobileBackLabel="Torna indietro">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="space-y-8">
    <section class="overflow-hidden rounded-[2rem] bg-white shadow-card">
      <div class="relative aspect-[4/4.8] sm:aspect-[16/6]">
        <img src={escursione.cover} alt={escursione.coverAlt || escursione.titolo} class="h-full w-full object-cover" loading="eager" />
        <div class="absolute inset-0 bg-gradient-to-t from-forest-800 via-forest-800/30 to-transparent"></div>

        <div class="absolute inset-x-0 bottom-0 p-6 text-white sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.16em] text-cream/80">{escursione.luogo}</p>
          <h1 class="mt-2 font-display text-4xl sm:text-5xl">{escursione.titolo}</h1>
          {heroDescription && <p class="mt-3 max-w-3xl text-sm text-cream/90 sm:text-base">{heroDescription}</p>}
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="grid gap-4 sm:grid-cols-2">
        <article class="rounded-[1.75rem] bg-white p-5 shadow-card"><p class="text-xs uppercase tracking-[0.16em] text-terracotta-600">Data</p><p class="mt-2 text-2xl font-black text-forest-800">{formatDate(escursione.data)}</p></article>
        <article class="rounded-[1.75rem] bg-white p-5 shadow-card"><p class="text-xs uppercase tracking-[0.16em] text-terracotta-600">Distanza</p><p class="mt-2 text-2xl font-black text-forest-800">{formatMetricValue(escursione.km, formatKilometers, " km")}</p></article>
        <article class="rounded-[1.75rem] bg-white p-5 shadow-card"><p class="text-xs uppercase tracking-[0.16em] text-terracotta-600">Durata</p><p class="mt-2 text-2xl font-black text-forest-800">{formatDurationValue(escursione.durata)}</p></article>
        <article class="rounded-[1.75rem] bg-white p-5 shadow-card"><p class="text-xs uppercase tracking-[0.16em] text-terracotta-600">Dislivello</p><p class="mt-2 text-2xl font-black text-forest-800">{formatMetricValue(escursione.dislivello, formatMeters, " m")}</p></article>
      </div>

      <div class="space-y-4 rounded-[2rem] bg-white p-6 shadow-card">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-terracotta-600">Compagnia</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {escursione.partecipanti.map((item) => <span class="rounded-full bg-cream px-4 py-2 text-sm font-bold text-forest-700">{partecipantiLabels[item] || item}</span>)}
          </div>
        </div>

        <div class="grid gap-4 lg:grid-cols-2">
          {escursione.nome_rifugio && (
            <div class="rounded-[1.5rem] bg-forest-50 p-5">
              <p class="text-xs font-bold uppercase tracking-[0.16em] text-terracotta-600">Rifugio</p>
              <p class="mt-2 text-2xl font-black text-forest-800">{escursione.nome_rifugio}</p>
            </div>
          )}

          <div class="rounded-[1.5rem] bg-forest-50 p-5">
            <p class="text-xs font-bold uppercase tracking-[0.16em] text-terracotta-600">Gea Rating</p>
            <div class="mt-3 flex items-center gap-2" aria-label={`Gea Rating: ${geaRating} su 5`}>
              {geaStars.map((starType) => (
                starType === "full" ? (
                  <Star
                    size={28}
                    strokeWidth={2}
                    class="text-terracotta-500 fill-terracotta-500"
                    aria-hidden="true"
                  />
                ) : starType === "half" ? (
                  <StarHalf
                    size={28}
                    strokeWidth={2}
                    class="text-terracotta-500 fill-terracotta-500"
                    aria-hidden="true"
                  />
                ) : (
                  <Star
                    size={28}
                    strokeWidth={2}
                    class="text-forest-200"
                    aria-hidden="true"
                  />
                )
              ))}
              </div>
          </div>
        </div>
      </div>
    </section>

    <section class="rounded-[2rem] border border-forest-950 bg-[#173328] p-3 shadow-card sm:p-4">
      <Mappa client:load escursioni={[escursione]} height="420px" />
    </section>

    {detailGalleryImages.length > 0 && <HikeGallery images={detailGalleryImages} />}
  </article>
</Layout>


