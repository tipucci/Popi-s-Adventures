---
import Layout from "../layouts/Layout.astro";
import Mappa from "../components/Mappa.jsx";
import { getEscursioni } from "../data/escursioni.js";

const escursioni = await getEscursioni();
---

<Layout
  title="Mappa | Popi's Adventures"
  description="Mappa dedicata con tutte le escursioni del diario che hanno coordinate disponibili."
  active="mappa"
>
  <section class="space-y-4">
    <div class="px-1 sm:px-2">
      <h1 class="font-display text-4xl text-forest-800 sm:text-5xl">In giro per il mondo</h1>
    </div>

    <div class="rounded-[2rem] border border-forest-950 bg-[#173328] p-3 shadow-card sm:p-4">
      <Mappa client:load escursioni={escursioni} height="560px" />
    </div>
  </section>
</Layout>