---
import { getImage } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import AboutUs from "../components/AboutUs.astro";
import CardEscursione from "../components/CardEscursione.jsx";
import { getEscursioni } from "../data/escursioni.js";
import { siteImages } from "../data/imageRegistry.js";
import heroHomeMobile from "../assets/images/site/home/popi-hero-mobile.webp";
import heroHomeDesktop from "../assets/images/site/home/popi-hero-desktop.webp";
import { withBase } from "../utils/base.js";
import { formatKilometers, formatMeters } from "../utils/format.js";

const escursioni = await getEscursioni();
const recenti = escursioni.slice(0, 3);
const hasEscursioni = escursioni.length > 0;
const [heroPreloadMobile, heroPreloadDesktop] = await Promise.all([
  getImage({ src: heroHomeMobile, width: 900, format: "webp", quality: 68 }),
  getImage({ src: heroHomeDesktop, width: 1440, format: "webp", quality: 74 })
]);


const stats = {
  uscite: escursioni.length,
  km: formatKilometers(escursioni.reduce((total, item) => total + item.km, 0)),
  dislivello: formatMeters(escursioni.reduce((total, item) => total + item.dislivello, 0)),
  conGea: escursioni.filter((item) => item.partecipanti.includes("gea")).length
};
---

<Layout
  title="Popi's Adventures | Un diario, tre popi e un sacco di avventure"
  description="Home del diario di escursioni con ultime uscite, statistiche e storie condivise."
  active="home"
>
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href={heroPreloadDesktop.src}
      imagesrcset={`${heroPreloadMobile.src} ${heroPreloadMobile.width}w, ${heroPreloadDesktop.src} ${heroPreloadDesktop.width}w`}
      imagesizes="100vw"
      fetchpriority="high"
    />
  </Fragment>
  <div class="space-y-10">
    <Header imageMobile={heroHomeMobile} imageDesktop={heroHomeDesktop} />

    <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
      <article class="rounded-[1.75rem] bg-white p-5 shadow-card">
        <p class="text-sm font-bold uppercase tracking-[0.16em] text-terracotta-600">Uscite</p>
        <p class="mt-3 text-4xl font-black text-forest-800">{stats.uscite}</p>
        <p class="mt-1 text-sm text-forest-700">Camminate salvate nel diario</p>
      </article>

      <article class="rounded-[1.75rem] bg-white p-5 shadow-card">
        <p class="text-sm font-bold uppercase tracking-[0.16em] text-terracotta-600">Km totali</p>
        <p class="mt-3 text-4xl font-black text-forest-800">{stats.km}</p>
        <p class="mt-1 text-sm text-forest-700">Distanza percorsa insieme</p>
      </article>

      <article class="rounded-[1.75rem] bg-white p-5 shadow-card">
        <p class="text-sm font-bold uppercase tracking-[0.16em] text-terracotta-600">Dislivello</p>
        <p class="mt-3 text-4xl font-black text-forest-800">{stats.dislivello} m</p>
        <p class="mt-1 text-sm text-forest-700">Somma totale delle salite</p>
      </article>

      <article class="rounded-[1.75rem] bg-white p-5 shadow-card">
        <p class="text-sm font-bold uppercase tracking-[0.16em] text-terracotta-600">Con Gea</p>
        <p class="mt-3 text-4xl font-black text-forest-800">{stats.conGea}</p>
        <p class="mt-1 text-sm text-forest-700">Escursioni con tutta la squadra</p>
      </article>
    </section>

    <section class="space-y-5">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.16em] text-terracotta-600">Ultime 3</p>
          <h2 class="text-3xl font-black text-forest-800">Le avventure più recenti</h2>
        </div>

        {hasEscursioni && (
          <a
            href={withBase("/escursioni")}
            class="hidden items-center justify-center rounded-full bg-forest-700 px-5 py-4 text-sm font-bold text-[#fffaf3] transition hover:bg-forest-600 lg:inline-flex"
          >
            <span class="text-[#fffaf3]">Tutte le escursioni</span>
          </a>
        )}
      </div>

      {hasEscursioni ? (
        <>
          <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {recenti.map((escursione) => (
              <CardEscursione escursione={escursione} />
            ))}
          </div>

          <div class="pt-2 lg:hidden">
            <a
              href={withBase("/escursioni")}
              class="inline-flex w-full items-center justify-center rounded-full bg-forest-700 px-5 py-4 text-sm font-bold text-[#fffaf3] transition hover:bg-forest-600 sm:w-auto"
            >
              <span class="text-[#fffaf3]">Vedi tutte le escursioni</span>
            </a>
          </div>
        </>
      ) : (
        <div class="rounded-[1.75rem] border border-dashed border-terracotta-300 bg-white/80 p-8 text-center text-forest-700 shadow-card">
          Il sito si è aperto, ma il CSV non ha risposto entro 8 secondi. Controlla la connessione oppure prova di nuovo tra poco.
        </div>
      )}
    </section>

    <AboutUs />
  </div>
</Layout>



